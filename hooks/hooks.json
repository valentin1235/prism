{
  "description": "Auto-bump plugin version on git push",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/bump-version.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
